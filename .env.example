# Copia a .env en la raíz del repositorio. Django (config/load_env.py) y la app Node
# (shopify_app/app/load-root-env.server.ts) leen este mismo archivo.

# --- Django ---
DJANGO_SECRET=

# --- Shopify (React Router / shopify_app) ---
# URL pública (debe coincidir con application_url en shopify_app/shopify.app.toml).
SHOPIFY_APP_URL=https://example.com

# Client ID y secret (Partners). client_id también está en shopify.app.toml.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Mismos scopes que shopify.app.toml [access_scopes], separados por comas.
SCOPES=write_products

# Puerto del servidor Node (p. ej. 8080 si el proxy apunta ahí).
PORT=8080

NODE_ENV=production

# Opcional: Prisma solo si tu schema usa env("DATABASE_URL").
# DATABASE_URL=

# Opcional: tienda con dominio custom.
# SHOP_CUSTOM_DOMAIN=
