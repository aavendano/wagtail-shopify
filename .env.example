# Copia a .env en la raíz del repositorio.

# --- Django ---
DJANGO_SECRET=
DJANGO_DEBUG=false

# --- PostgreSQL (producción) ---
DB_NAME=wagtail_shopify
DB_USER=wagtail_shopify_app
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Shopify ---
# URL pública (debe coincidir con application_url en shopify.app.toml).
SHOPIFY_APP_URL=https://cms.aadigitalbusiness.com

# Client ID y secret (Partners). client_id también está en shopify.app.toml.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Mismos scopes que shopify.app.toml [access_scopes], separados por comas.
SHOPIFY_SCOPES=read_content,read_online_store_pages,write_content,write_online_store_pages,read_products,write_products,read_metaobjects,write_metaobjects,read_metaobject_definitions,write_metaobject_definitions

# --- MCP (django-ninja-mcp) ---
# Fallback para tool calls internos cuando el cliente MCP no envía Authorization.
MCP_DEFAULT_API_KEY=

# --- Wagtail AI (Gemini) ---
GEMINI_API_KEY=
# Related pages (vector search). Requires pgvector on PostgreSQL — a superuser must run
# once: CREATE EXTENSION IF NOT EXISTS vector;  Then set WAGTAIL_AI_PGVECTOR=true and migrate.
# WAGTAIL_AI_PGVECTOR=true

# --- Celery (Redis broker, DB 1 aislada de otras apps) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_DEFAULT_QUEUE=wagtail_shopify
# CELERY_TASK_ALWAYS_EAGER=true

# --- Daphne ---
DAPHNE_BIND=127.0.0.1:8082
